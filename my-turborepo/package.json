{
  "name": "create-t3-turbo",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "start": "turbo start",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo clean",
    "db:push": "pnpm -F db push",
    "db:studio": "pnpm -F db studio",
    "depcheck": "check-dependency-version-consistency .",
    "depcheck:fix": "check-dependency-version-consistency . --fix",
    "dev": "turbo dev --parallel",
    "format": "turbo format --continue -- --cache --cache-location node_modules/.cache/.prettiercache",
    "format:fix": "turbo format --continue -- --write --cache --cache-location node_modules/.cache/.prettiercache",
    "postinstall": "pnpm lint:ws",
    "lint": "turbo lint --continue -- --cache --cache-location node_modules/.cache/.eslintcache",
    "lint:fix": "turbo lint --continue -- --fix --cache --cache-location node_modules/.cache/.eslintcache",
    "lint:ws": "pnpm dlx sherif@latest",
    "typecheck": "turbo typecheck",
    "ui-add": "pnpm -F ui ui-add"
  },
  "prettier": "@vanni/prettier-config",
  "devDependencies": {
    "@turbo/gen": "^2.4.4",
    "@vanni/prettier-config": "workspace:*",
    "check-dependency-version-consistency": "^4.1.1",
    "prettier": "^3.6.2",
    "turbo": "^2.4.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.12.0"
  },
  "pnpm": {
    "overrides": {
      "@better-auth/utils": "0.3.1",
      "rollup": "4.59.0",
      "fast-xml-parser": "5.3.8",
      "basic-ftp": "5.2.0",
      "node-forge": "1.3.2",
      "tar": "7.5.10",
      "minimatch": "3.1.4",
      "ws": "8.17.1",
      "immutable": "5.1.5",
      "serialize-javascript": "7.0.3",
      "@remix-run/router": "1.23.2",
      "nodemailer": "7.0.11",
      "glob": "10.5.0",
      "jws": "3.2.3",
      "next": "15.5.10",
      "preact": "10.27.3",
      "mdast-util-to-hast": "13.2.1",
      "lodash": "4.17.23",
      "react-router": "6.30.2",
      "undici": "6.23.0",
      "ajv": "8.18.0",
      "js-yaml": "4.1.1",
      "gray-matter>js-yaml": "3.14.1",
      "esbuild": "0.25.0",
      "diff": "4.0.4",
      "tmp": "0.2.4",
      "cookie": "0.7.0"
    }
  }
}
