{
  "name": "@vanni/datathon-blog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm with-env next build",
    "clean": "git clean -xdf .next .turbo node_modules",
    "dev": "pnpm with-env next dev --port 3001",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "pnpm with-env next start --port 3001",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env --"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "gray-matter": "^4.0.3",
    "next": "^16.1.6",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.3.5",
    "@types/nodemailer": "^7.0.11",
    "@types/nodemailer-ses-transport": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.56.1",
    "@vanni/eslint-config": "workspace:*",
    "@vanni/prettier-config": "workspace:*",
    "@vanni/tailwind-config": "workspace:*",
    "@vanni/tsconfig": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.2",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  }
}
